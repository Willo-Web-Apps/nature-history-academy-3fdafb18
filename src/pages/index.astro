---
import Base from '../layouts/Base.astro';
---
<Base
  title="Wildroot Academy — Rooted in Faith. Alive with Wonder."
  description="Free resources, activity guides, and learning paths for Christian homeschool families exploring nature, history, and science together."
>

  <!-- ═══════════════════════════════════════════════════════
       HERO — Immersive forest morning, layered gradients
  ═══════════════════════════════════════════════════════ -->
  <section class="relative min-h-[92vh] flex items-center overflow-hidden hero-grain"
    style="
      background:
        radial-gradient(ellipse 70% 60% at 92% 8%,  oklch(0.72 0.10 68 / 0.30) 0%, transparent 65%),
        radial-gradient(ellipse 80% 70% at 5%  90%, oklch(0.38 0.08 145 / 0.35) 0%, transparent 60%),
        radial-gradient(ellipse 50% 40% at 55% 20%, oklch(0.56 0.10 145 / 0.12) 0%, transparent 55%),
        linear-gradient(165deg, oklch(0.97 0.018 88) 0%, oklch(0.96 0.022 82) 50%, oklch(0.94 0.026 80) 100%);
    "
  >

    <!-- Floating botanical accent — top right -->
    <div class="absolute top-0 right-0 w-64 md:w-96 opacity-10 pointer-events-none select-none" aria-hidden="true">
      <svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <g fill="none" stroke="oklch(0.38 0.08 145)" stroke-width="1.5" stroke-linecap="round">
          <!-- Main branch -->
          <path d="M380 20 C320 80, 280 160, 200 220"/>
          <!-- Left leaflets -->
          <path d="M320 70 C290 45, 255 50, 248 75 C260 68, 290 72, 320 70Z"/>
          <path d="M290 110 C255 82, 218 90, 214 116 C228 108, 262 112, 290 110Z"/>
          <path d="M258 152 C220 122, 183 132, 180 158 C194 150, 230 152, 258 152Z"/>
          <!-- Right leaflets -->
          <path d="M348 92 C370 65, 390 70, 388 96 C378 88, 360 90, 348 92Z"/>
          <path d="M316 134 C340 108, 360 114, 358 140 C347 132, 328 135, 316 134Z"/>
          <!-- Small berries -->
          <circle cx="200" cy="222" r="3" fill="oklch(0.62 0.13 52 / 0.4)" stroke="none"/>
          <circle cx="210" cy="230" r="2" fill="oklch(0.62 0.13 52 / 0.3)" stroke="none"/>
        </g>
      </svg>
    </div>

    <!-- Floating botanical accent — bottom left -->
    <div class="absolute bottom-0 left-0 w-48 md:w-72 opacity-8 pointer-events-none select-none animate-float" aria-hidden="true">
      <svg viewBox="0 0 300 280" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <g fill="none" stroke="oklch(0.43 0.09 145)" stroke-width="1.2" stroke-linecap="round">
          <path d="M10 280 C50 230, 90 180, 120 120"/>
          <path d="M60 220 C30 195, 10 205, 15 228 C26 220, 48 222, 60 220Z"/>
          <path d="M90 175 C58 148, 35 160, 40 183 C52 175, 78 177, 90 175Z"/>
          <path d="M85 200 C115 175, 135 180, 130 204 C118 196, 97 198, 85 200Z"/>
          <path d="M112 145 C140 118, 160 124, 155 148 C143 140, 124 142, 112 145Z"/>
        </g>
      </svg>
    </div>

    <div class="relative z-10 max-w-5xl mx-auto px-6 sm:px-8 lg:px-12 py-24 md:py-32">
      <!-- Eyebrow label -->
      <div class="section-ornament animate-fade-in" style="justify-content: flex-start; margin-bottom: 1.5rem;">
        <div class="ornament-line"></div>
        <span class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-500" style="color: oklch(0.62 0.13 52);">Christian Homeschool Resources</span>
        <div class="ornament-line-rev" style="background: linear-gradient(to right, transparent, oklch(0.62 0.13 52 / 0.5));"></div>
      </div>

      <!-- Main headline — Lora serif, dramatic scale -->
      <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl font-bold leading-[1.08] tracking-tight text-surface-900 max-w-3xl animate-slide-up"
        style="color: oklch(0.22 0.028 78);">
        Where Faith, Nature,<br/>
        <em class="font-normal not-italic" style="color: oklch(0.38 0.08 145);">and Learning</em><br/>
        Come Alive
      </h1>

      <p class="mt-6 text-lg md:text-xl font-body leading-relaxed max-w-xl animate-slide-up delay-100"
        style="color: oklch(0.38 0.032 78); font-weight: 400;">
        Free resources, activity guides, and learning paths for Christian homeschool families
        exploring nature, history, and science — all together, all with wonder.
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-col sm:flex-row gap-4 animate-slide-up delay-200">
        <a href="#resources"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-2xl font-semibold text-base transition-all duration-200 hover:-translate-y-0.5"
          style="background: oklch(0.43 0.09 145); color: oklch(0.97 0.010 88); box-shadow: 0 4px 16px oklch(0.38 0.08 145 / 0.30);"
          onmouseover="this.style.background='oklch(0.34 0.08 145)'"
          onmouseout="this.style.background='oklch(0.43 0.09 145)'">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
            <path d="M10.75 2.75a.75.75 0 0 0-1.5 0v8.614L6.295 8.235a.75.75 0 1 0-1.09 1.03l4.25 4.5a.75.75 0 0 0 1.09 0l4.25-4.5a.75.75 0 0 0-1.09-1.03l-2.955 3.129V2.75Z"/>
            <path d="M3.5 12.75a.75.75 0 0 0-1.5 0v2.5A2.75 2.75 0 0 0 4.75 18h10.5A2.75 2.75 0 0 0 18 15.25v-2.5a.75.75 0 0 0-1.5 0v2.5c0 .69-.56 1.25-1.25 1.25H4.75c-.69 0-1.25-.56-1.25-1.25v-2.5Z"/>
          </svg>
          Explore Free Resources
        </a>
        <a href="#join"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-2xl font-semibold text-base border-2 transition-all duration-200 hover:-translate-y-0.5"
          style="border-color: oklch(0.43 0.09 145); color: oklch(0.43 0.09 145); background: transparent;"
          onmouseover="this.style.background='oklch(0.43 0.09 145 / 0.06)'"
          onmouseout="this.style.background='transparent'">
          Join Our Community
        </a>
      </div>

      <!-- Micro proof -->
      <p class="mt-6 text-sm animate-slide-up delay-300" style="color: oklch(0.50 0.04 78);">
        ✦ No login required &nbsp;·&nbsp; Always free to explore &nbsp;·&nbsp; Trusted by families in 40+ states
      </p>
    </div>

    <!-- Bottom wave divider into impact stats -->
    <div class="wave-bottom" aria-hidden="true">
      <svg viewBox="0 0 1440 72" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,72 C240,20 480,60 720,36 C960,12 1200,52 1440,24 L1440,72 Z" fill="oklch(0.96 0.022 82)"/>
      </svg>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       IMPACT STATS — Big numbers, asymmetric layout
  ═══════════════════════════════════════════════════════ -->
  <section class="relative py-20 md:py-28 overflow-hidden" style="background: oklch(0.96 0.022 82);">

    <div class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-12">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Left: pull quote / mission statement -->
        <div>
          <div class="section-ornament" style="justify-content: flex-start; margin-bottom: 1.25rem;">
            <div class="ornament-line"></div>
            <span class="text-xs font-semibold uppercase tracking-[0.18em]" style="color: oklch(0.62 0.13 52);">Our Heart</span>
          </div>
          <blockquote class="font-display text-2xl md:text-3xl font-medium italic leading-[1.35]" style="color: oklch(0.30 0.025 80);">
            "Learning should feel like a morning walk — full of questions, wonder, and the quiet knowledge that God made all of this."
          </blockquote>
          <p class="mt-6 text-base leading-relaxed" style="color: oklch(0.42 0.035 78);">
            Wildroot Academy was born from a simple belief: that Christian homeschool families deserve beautiful, multi-age resources that honor both academic rigor and Biblical wonder. Every guide, printable, and learning path we offer is crafted with that vision.
          </p>
          <!-- Signature-style flourish -->
          <div class="mt-6 flex items-center gap-3">
            <div style="width: 2.5rem; height: 2px; background: oklch(0.62 0.13 52 / 0.6);"></div>
            <span class="font-display italic text-sm" style="color: oklch(0.62 0.13 52);">The Wildroot Team</span>
          </div>
        </div>

        <!-- Right: impact stats grid -->
        <div class="grid grid-cols-2 gap-8">
          <div class="text-center p-6 rounded-2xl resource-card">
            <div class="font-display font-bold leading-none mb-2" style="font-size: 3.5rem; color: oklch(0.43 0.09 145);">2,400+</div>
            <div class="text-sm font-semibold uppercase tracking-wider" style="color: oklch(0.45 0.04 78);">Free Resources</div>
          </div>
          <div class="text-center p-6 rounded-2xl resource-card" style="margin-top: 2rem;">
            <div class="font-display font-bold leading-none mb-2" style="font-size: 3.5rem; color: oklch(0.62 0.13 52);">14K+</div>
            <div class="text-sm font-semibold uppercase tracking-wider" style="color: oklch(0.45 0.04 78);">Families Reached</div>
          </div>
          <div class="text-center p-6 rounded-2xl resource-card" style="margin-top: -1rem;">
            <div class="font-display font-bold leading-none mb-2" style="font-size: 3.5rem; color: oklch(0.62 0.13 52);">3</div>
            <div class="text-sm font-semibold uppercase tracking-wider" style="color: oklch(0.45 0.04 78);">Core Subjects</div>
            <div class="text-xs mt-1" style="color: oklch(0.55 0.04 78);">Nature · History · Science</div>
          </div>
          <div class="text-center p-6 rounded-2xl resource-card">
            <div class="font-display font-bold leading-none mb-2" style="font-size: 3.5rem; color: oklch(0.43 0.09 145);">All</div>
            <div class="text-sm font-semibold uppercase tracking-wider" style="color: oklch(0.45 0.04 78);">Ages Together</div>
            <div class="text-xs mt-1" style="color: oklch(0.55 0.04 78);">K–8 multi-age design</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Wave into how it works -->
    <div class="wave-bottom" aria-hidden="true">
      <svg viewBox="0 0 1440 64" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,0 C360,64 720,20 1080,52 C1260,64 1360,44 1440,36 L1440,64 L0,64 Z" fill="oklch(0.985 0.010 88)"/>
      </svg>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       HOW IT WORKS — 3 steps, visual
  ═══════════════════════════════════════════════════════ -->
  <section class="relative py-24 md:py-32 overflow-hidden" style="background: oklch(0.985 0.010 88);" id="resources">

    <!-- Background dot pattern -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
      style="background-image: radial-gradient(circle at 1px 1px, oklch(0.38 0.08 145 / 0.06) 1px, transparent 0); background-size: 28px 28px; mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 40%, transparent 100%);">
    </div>

    <div class="relative z-10 max-w-5xl mx-auto px-6 sm:px-8 lg:px-12">

      <div class="text-center mb-16">
        <div class="section-ornament mb-4">
          <div class="ornament-line"></div>
          <!-- Leaf ornament SVG -->
          <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="oklch(0.62 0.13 52)" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c0 0-4.5 4.5-4.5 9a4.5 4.5 0 0 0 9 0C16.5 7.5 12 3 12 3Z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 12v9"/>
          </svg>
          <div class="ornament-line-rev"></div>
        </div>
        <h2 class="font-display text-4xl md:text-5xl font-bold" style="color: oklch(0.22 0.028 78);">
          Learning Made for Real Families
        </h2>
        <p class="mt-4 text-lg max-w-xl mx-auto" style="color: oklch(0.42 0.035 78);">
          No overwhelm. No scattered bookmarks. Just a warm, organized path into beautiful learning.
        </p>
      </div>

      <!-- Steps — flowing layout -->
      <div class="grid md:grid-cols-3 gap-8 md:gap-6 relative">
        <!-- Step connector line (desktop only) -->
        <div class="hidden md:block absolute top-12 left-1/4 right-1/4 h-px" style="background: linear-gradient(to right, oklch(0.43 0.09 145 / 0.2), oklch(0.62 0.13 52 / 0.4), oklch(0.43 0.09 145 / 0.2)); z-index: 0;"></div>

        <!-- Step 1 -->
        <div class="relative z-10 text-center px-4">
          <div class="w-20 h-20 rounded-full mx-auto mb-6 flex items-center justify-center relative"
            style="background: oklch(0.96 0.02 145);">
            <span class="font-display font-bold text-2xl" style="color: oklch(0.43 0.09 145);">1</span>
            <!-- Small leaf accent -->
            <div class="absolute -top-1 -right-1 w-5 h-5 rounded-full flex items-center justify-center" style="background: oklch(0.62 0.13 52);">
              <svg viewBox="0 0 12 12" class="w-3 h-3" fill="white" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M6 1C6 1 3 4 3 7.5C3 9.43 4.34 11 6 11C7.66 11 9 9.43 9 7.5C9 4 6 1 6 1Z"/>
              </svg>
            </div>
          </div>
          <h3 class="font-display text-xl font-semibold mb-3" style="color: oklch(0.28 0.028 78);">Choose a Subject Trail</h3>
          <p class="text-base leading-relaxed" style="color: oklch(0.45 0.04 78);">
            Browse learning paths organized by nature study, history, or science — each designed for multiple ages learning side by side.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="relative z-10 text-center px-4 md:mt-8">
          <div class="w-20 h-20 rounded-full mx-auto mb-6 flex items-center justify-center relative"
            style="background: oklch(0.95 0.04 60);">
            <span class="font-display font-bold text-2xl" style="color: oklch(0.52 0.12 50);">2</span>
            <div class="absolute -top-1 -right-1 w-5 h-5 rounded-full flex items-center justify-center" style="background: oklch(0.62 0.13 52);">
              <svg viewBox="0 0 12 12" class="w-3 h-3" fill="white" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M6 1C6 1 3 4 3 7.5C3 9.43 4.34 11 6 11C7.66 11 9 9.43 9 7.5C9 4 6 1 6 1Z"/>
              </svg>
            </div>
          </div>
          <h3 class="font-display text-xl font-semibold mb-3" style="color: oklch(0.28 0.028 78);">Download &amp; Print</h3>
          <p class="text-base leading-relaxed" style="color: oklch(0.45 0.04 78);">
            Grab beautifully designed activity packs, nature journal pages, and guides — no account needed, no barriers between you and the resources.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="relative z-10 text-center px-4">
          <div class="w-20 h-20 rounded-full mx-auto mb-6 flex items-center justify-center relative"
            style="background: oklch(0.96 0.02 145);">
            <span class="font-display font-bold text-2xl" style="color: oklch(0.43 0.09 145);">3</span>
            <div class="absolute -top-1 -right-1 w-5 h-5 rounded-full flex items-center justify-center" style="background: oklch(0.62 0.13 52);">
              <svg viewBox="0 0 12 12" class="w-3 h-3" fill="white" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M6 1C6 1 3 4 3 7.5C3 9.43 4.34 11 6 11C7.66 11 9 9.43 9 7.5C9 4 6 1 6 1Z"/>
              </svg>
            </div>
          </div>
          <h3 class="font-display text-xl font-semibold mb-3" style="color: oklch(0.28 0.028 78);">Learn Together, Outside</h3>
          <p class="text-base leading-relaxed" style="color: oklch(0.45 0.04 78);">
            Take the learning outside. Our guides are built for nature walks, kitchen science, and living history — real learning in real places.
          </p>
        </div>
      </div>
    </div>

    <!-- Wave into resource cards -->
    <div class="wave-bottom" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,35 C200,70 400,0 720,35 C900,52 1200,10 1440,40 L1440,70 L0,70 Z" fill="oklch(0.972 0.014 85)"/>
      </svg>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       MEMBER STORIES / SPOTLIGHT — Community warmth
  ═══════════════════════════════════════════════════════ -->
  <section class="relative py-24 md:py-32 overflow-hidden" style="background: oklch(0.972 0.014 85);">

    <div class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-12">

      <div class="text-center mb-16">
        <div class="section-ornament mb-4">
          <div class="ornament-line"></div>
          <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="oklch(0.62 0.13 52)" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c0 0-4.5 4.5-4.5 9a4.5 4.5 0 0 0 9 0C16.5 7.5 12 3 12 3Z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 12v9"/>
          </svg>
          <div class="ornament-line-rev"></div>
        </div>
        <h2 class="font-display text-4xl md:text-5xl font-bold" style="color: oklch(0.22 0.028 78);">
          From Our Community
        </h2>
        <p class="mt-4 text-lg max-w-xl mx-auto" style="color: oklch(0.42 0.035 78);">
          Real families, real wonder. What happens when learning feels beautiful and purposeful.
        </p>
      </div>

      <!-- Story cards — asymmetric sizes -->
      <div class="grid md:grid-cols-3 gap-6 items-start">

        <!-- Featured large testimonial -->
        <div class="md:col-span-2 resource-card p-8 md:p-10 relative overflow-hidden">
          <!-- Background leaf watermark -->
          <div class="absolute -bottom-4 -right-4 w-32 h-32 opacity-5 pointer-events-none" aria-hidden="true">
            <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
              <path d="M50 5C50 5 20 30 20 60C20 78 33 92 50 92C67 92 80 78 80 60C80 30 50 5 50 5Z" fill="oklch(0.43 0.09 145)" stroke="none"/>
            </svg>
          </div>
          <div class="flex gap-1 mb-4" aria-label="5 stars">
            {[1,2,3,4,5].map(() => (
              <svg class="w-5 h-5" viewBox="0 0 20 20" fill="oklch(0.72 0.12 55)" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292Z"/>
              </svg>
            ))}
          </div>
          <blockquote class="font-display text-xl md:text-2xl italic font-medium leading-relaxed mb-6" style="color: oklch(0.28 0.028 78);">
            "I've spent years trying to find resources that work for my 7-year-old AND my 12-year-old at the same time. Wildroot is the first place that actually gets it. My kids asked if we could do 'school' on Saturday."
          </blockquote>
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full flex items-center justify-center font-display font-bold text-lg" style="background: oklch(0.91 0.04 145); color: oklch(0.43 0.09 145);">S</div>
            <div>
              <div class="font-semibold text-sm" style="color: oklch(0.28 0.028 78);">Sarah M.</div>
              <div class="text-sm" style="color: oklch(0.52 0.04 78);">Homeschooling mom of 3 · Tennessee</div>
            </div>
          </div>
        </div>

        <!-- Smaller testimonials stacked -->
        <div class="flex flex-col gap-6">
          <div class="resource-card p-6">
            <div class="flex gap-1 mb-3" aria-label="5 stars">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4" viewBox="0 0 20 20" fill="oklch(0.72 0.12 55)" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292Z"/>
                </svg>
              ))}
            </div>
            <blockquote class="text-base italic font-display leading-relaxed mb-4" style="color: oklch(0.32 0.028 78);">
              "The nature journal printables alone are worth everything. My daughter fills one every single week."
            </blockquote>
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full flex items-center justify-center font-display font-bold" style="background: oklch(0.95 0.04 60); color: oklch(0.52 0.12 50);">R</div>
              <div>
                <div class="font-semibold text-xs" style="color: oklch(0.28 0.028 78);">Rachel K.</div>
                <div class="text-xs" style="color: oklch(0.52 0.04 78);">Mom of 2 · Oregon</div>
              </div>
            </div>
          </div>

          <div class="resource-card p-6">
            <div class="flex gap-1 mb-3" aria-label="5 stars">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4" viewBox="0 0 20 20" fill="oklch(0.72 0.12 55)" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
