---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = "Wildroot Academy — Rooted in Faith. Alive with Wonder.", description = "Free resources, activity guides, and learning paths for Christian homeschool families exploring nature, history, and science together." } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Wildroot Academy",
      "description": "Free resources, activity guides, and learning paths for Christian homeschool families exploring nature, history, and science together.",
      "url": "https://nature-history-academy.onrender.com"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col font-body antialiased" style="background: oklch(0.985 0.010 88); color: oklch(0.22 0.028 78);">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
